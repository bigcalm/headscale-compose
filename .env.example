# ── Domain ────────────────────────────────────────────
# Also update the server_url in headscale-config/config.yaml to match
DOMAIN=headscale.example.com

# Base domain for MagicDNS hostnames
# Must differ from DOMAIN, and DOMAIN must NOT be a subdomain of this value.
# Also update base_domain in headscale-config/config.yaml
# Example: if DOMAIN=headscale.example.com, BASE_DOMAIN could be int.example.com
BASE_DOMAIN=int.example.com

# ── Timezone ─────────────────────────────────────────
TZ=UTC

# ── Container image versions ─────────────────────────
# Set these to the version tags you want to run.
# See the "Updating" section in README.md for help finding latest versions.

HS_VERSION=v0.28.0
UI_VERSION=2026.03.17
CADDY_VERSION=2.11.3
