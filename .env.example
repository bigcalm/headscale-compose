# Your domain where headscale will be accessible
# Also update the server_url in headscale-config/config.yaml to match
DOMAIN=headscale.example.com

# Base domain for MagicDNS hostnames (must differ from server_url domain)
# Also update base_domain in headscale-config/config.yaml
# Example: if DOMAIN=headscale.example.com, BASE_DOMAIN could be vpn.example.com
BASE_DOMAIN=example.com

# Timezone (optional, defaults to UTC)
TZ=UTC
